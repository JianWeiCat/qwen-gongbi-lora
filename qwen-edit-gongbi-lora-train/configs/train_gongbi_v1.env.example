# Copy this file to train_gongbi_v1.env on the remote server if you want
# shell-style configuration instead of passing CLI flags.

DATASET_BASE_PATH=/path/to/qwen-gongbi-lora/qwen-edit-gongbi-lora-train/data/gongbi_v1
DATASET_METADATA_PATH=/path/to/qwen-gongbi-lora/qwen-edit-gongbi-lora-train/data/gongbi_v1/metadata.json
OUTPUT_PATH=/path/to/qwen-gongbi-lora/qwen-edit-gongbi-lora-train/outputs/lora_v1

MAX_PIXELS=786432
DATASET_REPEAT=50
LEARNING_RATE=1e-4
NUM_EPOCHS=5
LORA_RANK=16
DATASET_NUM_WORKERS=8

